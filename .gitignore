# ====================================================
# ARTICLE PLATFORM - Root .gitignore
# Covers: Backend (Java/Spring/Maven) + Frontend (React/Vite)
# ====================================================

# ====================================================
# Operating System Files
# ====================================================
.DS_Store
Thumbs.db
*.sw?
*.swo
*.lock
Desktop.ini

# ====================================================
# IDEs and Editors
# ====================================================

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/dictionaries
.idea/**/shelf

# VS Code
.vscode/
!.vscode/extensions.json
.vscode-test/

# Eclipse
.project
.classpath
.settings/
bin/

# NetBeans
nbproject/
nb-configuration.xml
build/
dist/
nbbuild/
nbdist/

# ====================================================
# Backend - Java / Maven / Spring Boot
# ====================================================

# Maven build output
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties

# Maven wrapper
.mvn/wrapper/maven-wrapper.jar

# Java compiled files
*.class
*.jar
*.war
*.ear
*.jks

# Log files
*.log
logs/
**/logs/

# Backup files
*.bak
*.orig

# ====================================================
# Frontend - React / Vite / NPM
# ====================================================

# Dependencies
node_modules/
**/node_modules/

# Build outputs
dist/
dist-ssr/
**/dist/
**/dist-ssr/

# Vite cache
.vite/
**/.vite/

# Environment variables (contains secrets)
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# NPM / Yarn logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# Package manager locks (keep these - uncomment if you want to ignore)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# TypeScript cache
*.tsbuildinfo
**/*.tsbuildinfo

# Vite config generated files
vite.config.js.timestamp-*
**/vite.config.js.timestamp-*

# React / Vite specific temp files
.parcel-cache/
.cache/
**/.parcel-cache/
**/.cache/

# Coverage directory
coverage/
**/coverage/

# ====================================================
# Docker & Containerization
# ====================================================

# Docker volumes (if mounted locally)
volumes/
**/volumes/

# Docker compose overrides (local only)
docker-compose.override.yml
docker-compose.*.yml

# ====================================================
# Build & Generated Files (General)
# ====================================================

# Build directories
build/
out/
target/
**/build/
**/out/
**/target/

# Archive files
*.zip
*.tar
*.tar.gz
*.rar
*.7z
*.iso

# ====================================================
# Large Files & Data
# ====================================================

# Database files
*.db
*.sqlite
*.sqlite3

# Large datasets / binaries
*.bin
*.dat

# Media files (uncomment if needed)
# *.mp4
# *.mov
# *.avi
# *.mkv
# *.png
# *.jpg
# *.jpeg
# *.gif

# ====================================================
# Application Specific
# ====================================================

# Java crash logs
hs_err_pid*
replay_pid*

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# ====================================================
# Miscellaneous
# ====================================================

# Temporary files
tmp/
temp/
**/tmp/
**/temp/

# Local development files
*.local
**/*.local

# SSH keys or sensitive files (uncomment if needed)
# *.pem
# *.key
# *.crt
# *.p12

# ====================================================
# Documentation build outputs (if any)
# ====================================================

# API docs generated
docs/api/generated/
**/docs/api/generated/

# ====================================================
# Testing outputs
# ====================================================

# Test reports
test-reports/
**/test-reports/
surefire-reports/
**/surefire-reports/
failsafe-reports/
**/failsafe-reports/