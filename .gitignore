# =========================
# Vite / React Frontend
# =========================

# Dependencies (always ignore)
node_modules/
**/node_modules/

# Vite build output
dist/
**/dist/
dist-ssr/
**/dist-ssr/

# Vite cache
.vite/
**/.vite/

# Environment variables (if you have sensitive keys)
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# NPM / Yarn logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# Package manager locks (optional - team preference)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Build artifacts
**/build/
**/out/

# TypeScript cache
*.tsbuildinfo
**/*.tsbuildinfo

# Vite config generated files
vite.config.js.timestamp-*
**/vite.config.js.timestamp-*

# React / Vite specific temp files
**/.parcel-cache/
**/.cache/

# Coverage directory (if you add testing later)
coverage/
**/coverage/

# Miscellaneous
*.local
**/*.local

# Any nested frontend folders (customize path if needed)
# Example if frontend is at: /frontend/my-articles-frontend/
# frontend/**/node_modules/
# frontend/**/dist/
# frontend/**/.vite/